# Python caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Virtual environments
.venv/
venv/
env/
ENV/

# Build and packaging output
build/
dist/
*.egg-info/

# Local secrets and machine-specific config
.env
.env.*
*.pem
*.key
*.p12
*.pfx
secrets.*
credentials.*

# Editor, OS, and temporary files
.DS_Store
Thumbs.db
Desktop.ini
*.tmp
*.temp
*.bak
*.swp
*.swo
~$*

# Logs and generated report build byproducts
*.log
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.out
*.synctex.gz
*.toc

# Large binary media and archive bundles
*.mp4
*.avi
*.mov
*.mkv
*.zip
*.tar
*.tar.gz
*.tgz
*.7z

# Temporary or known-failed experiment scratch spaces
experiments/logs/tmp*/
experiments/logs/**/_failed_bug_runs*/
experiments/logs/**/*failed_bug*/
